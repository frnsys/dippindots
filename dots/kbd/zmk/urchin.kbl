ALPHA

Q L D C B  . F O U J
N R T S G  Y H A E I
X V M W Z  K P , ' /
      вМЂ s  вПО вР£

holds:
  вР£: Ctrl
  вПО: Layer(ARROWS)
  ',': Layer(NUMSYM)

defs:
  s: Shift

combos:
  # Layers
  [H, I]: Enable(SYSTEM)
  [N, S]: Enable(SYSTEM)

  # Modifiers
  [P, "'"]: OneShot(Meta)
  [вМЂ, Q]: OneShot(Ctrl)        # Useful for e.g. ctrl+mousewheel
  [N, R, S]: OneShot(Meta)     # Useful for e.g. meta-mousedrag

  # Shortcuts
  [N, R, T]: Shift(вОЛ)
  [R, T, S]: Shift(Alt(C))     # Terminal copy
  [N, R, T, S]: Shift(Alt(P))  # Terminal paste
  [W, Z]: Ctrl(Z)              # Undo
  [X, V, M, W]: вЖЇ              # Bootloader

  # Accents
  [N, вМЂ]: "ЋЖ"
  [R, вМЂ]: "¬і"
  [T, вМЂ]: "ЋЛ"
  [G, вМЂ]: "¬®"
  [S, вМЂ]: "вВђ"
  [O, вР£]: "¬Є"

  # Special
  [V, W]: "вОЛ"
  [R, T]: "вОЛ"
  [T, S]: "вЗ•"

  # Symbols
  [H, E]: '='
  [H, A]: ":"
  [A, E]: "-"
  [D, C]: "&"
  [O, U]: "_"
  [L, D]: "*"
  [H, U]: '`'
  [X, V]: "~"
  [",", "'"]: ">"
  ["V", "M"]: "<"

  # For Blender
  [C, L]: "Y"

shifts:
  '-': '+'
  ',': '?'
  "'": '"'
  '=': '!'
  '*': '@'
  ':': ';'
  '_': '|'
  '.': '&'
  '`': "%"
  '>': '}'
  '<': '{'
  '/': '\\'
  вР£: Enable(NUMSYM)

