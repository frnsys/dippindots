NUMSYM

. 4 5 6 вђЪ  вђЪ # [ ] $
0 1 2 3 вђЪ  вђЪ { ( ) }
, 7 8 9 вђЪ  вђЪ _ < > ^
      вМЂ 0  вђЪ вђЪ

combos:
  ["1", "3"]: "0"
  ["2", "3"]: "4"
  ["1", "2"]: "5"

