#!/bin/bash

if [[ $1 == 'start' ]]; then
    TIME=$(date +%F-%T)
    FRAMERATE=30 # Record at a constant frame rate
    VID=~/docs/recs/recording_${TIME}.mkv # Don't record to /tmp as it's space-limited

    TARGET=$(echo -e "eDP-1\nDP-1\nregion" | bemenu -p "Target:")
    [ -z "$TARGET_CHOICE" ] && exit 0

    FLAGS=""
    # FLAGS="-a" # For audio

    case "$TARGET" in
        "region")
            GEOM=$(slurp)
            [ -n "$GEOM" ] && wf-recorder $FLAGS -g "$GEOM" -r $FRAMERATE -f "$VID"
            ;;
        *)
            wf-recorder $FLAGS -o "$TARGET" -r $FRAMERATE -f "$VID"
            ;;
    esac

    notify-send "[rec] finished: ${VID}"
elif [[ $1 == 'stop' ]]; then
    pkill wf-recorder
fi
